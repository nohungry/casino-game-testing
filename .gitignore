# Brand 校準結果由 AI 在本機產生，不入 repo（每個 QA 自己 calibrate）
brands/*.yaml
!brands/_schema.yaml
!brands/_template.yaml

# 測試報告 / 截圖 / 中繼檔
reports/
tmp/
*.log

# 根目錄的臨時截圖/影像（測試過程 browser_take_screenshot 落在 repo 根，屬 scratch，不入 repo）
# 只擋根層（前置 /），docs/ 等子目錄的正式圖不受影響
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
/*.bmp

# Playwright MCP 執行工件（snapshot / console log）
.playwright-mcp/

# Python 環境（uv）：.venv 不入 repo；pyproject.toml / uv.lock / .python-version 要 commit（給團隊重現）
.venv/
__pycache__/
*.pyc

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# Claude Code 本機設定（個人權限不要污染團隊）
.claude/settings.local.json

# MCP 設定含本機 Chromium 路徑（含使用者名稱），各人本機自己填
# 共用範本是 .mcp.json.example；clone 後 cp .mcp.json.example .mcp.json 再填路徑
.mcp.json
!.mcp.json.example
scripts/secret-scan.local-patterns
